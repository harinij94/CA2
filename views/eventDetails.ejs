<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <title><%= event.eventName %></title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
</head>

<body>
    <nav class="navbar navbar-expand-sm bg-dark navbar-dark">
        <div class="container-fluid">
            <a class="navbar-brand" href="/">Event Management App</a>
            <ul class="navbar-nav">
                <li class="nav-item">
                    <a class="nav-link" href="/events">View Events</a>
                </li>
                <% if (user && user.role === 'admin') { %>
                    <li class="nav-item">
                        <a class="nav-link" href="/addEvent">Add Event</a>
                    </li>
                <% } %>
                <li class="nav-item">
                    <a class="nav-link" href="/logout">Logout (<%= user.username %>)</a>
                </li>
            </ul>
        </div>
    </nav>

    <div class="container mt-4" style="max-width: 700px;">
        <a href="/events" class="btn btn-secondary btn-sm mb-3">&larr; Back to All Events</a>

        <div class="card shadow-sm">
            <div class="card-body">
                <h2 class="card-title"><%= event.eventName %></h2>
                <h6 class="card-subtitle mb-3 text-muted">📍 <%= event.location %></h6>
                <p><strong>Date:</strong> <%= event.formattedDate %></p>
                <p><%= event.description %></p>
            </div>

            <% if (user && user.role === 'admin') { %>
                <div class="card-footer bg-transparent d-flex gap-2">
                    <a href="/editEvent/<%= event.eventId %>" class="btn btn-warning btn-sm">Edit</a>
                    <form action="/deleteEvent/<%= event.eventId %>" method="POST" onsubmit="return confirm('Delete this event?');">
                        <button type="submit" class="btn btn-danger btn-sm">Delete</button>
                    </form>
                </div>
            <% } %>
        </div>
    </div>
</body>

</html>
