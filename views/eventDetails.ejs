<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= event.eventName %></title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="bg-light">

    <nav class="navbar navbar-expand-sm bg-dark navbar-dark">
        <div class="container-fluid">
            <a class="navbar-brand" href="/">Event Management App</a>
            <ul class="navbar-nav">
                <li class="nav-item"><a class="nav-link" href="/events">View Events</a></li>
                <li class="nav-item"><a class="nav-link" href="/addEvent">Add Event</a></li>
            </ul>
        </div>
    </nav>

    <div class="container mt-5">
        <div class="card shadow-sm p-4">
            <h1 class="display-5 fw-bold"><%= event.eventName %></h1>
            <p class="text-muted fs-5">📍 <%= event.location %></p>
            <p class="fw-bold text-primary">📅 <%= event.formattedDate %></p>
            
            <hr>
            
            <h5>Description</h5>
            <p class="fs-6"><%= event.description %></p>

            <div class="mt-4">
                <a href="/events" class="btn btn-secondary">← Back to All Events</a>
                <a href="/editEvent/<%= event.eventId %>" class="btn btn-warning ms-2">Edit Event</a>
            </div>
        </div>
    </div>

</body>
</html>