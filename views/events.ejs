<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>All Events</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
</head>

<body>
        <nav class="navbar navbar-expand-sm bg-dark navbar-dark">
        <div class="container-fluid">
            <a class="navbar-brand" href="/">Event Management App</a>
            <ul class="navbar-nav">
                <li class="nav-item">
                    <a class="nav-link" href="/events">View Events</a>
                </li>

                <li class="nav-item">
                    <a class="nav-link" href="/addEvent">Add Event</a>
                </li>

                <li class="nav-item">
                    <a class="nav-link" href="/login">Login</a>
                </li>

                <li class="nav-item">
                    <a class="nav-link" href="/register">Register</a>
                </li>

            </ul>
        </div>
    </nav>

    <div class="container mt-4">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h2>All Events</h2>
            <a href="/addEvent" class="btn btn-success">+ Add New Event</a>
        </div>

        <% if (events && events.length > 0) { %>
            <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
                <% events.forEach(event => { %>
                    <div class="col">
                        <div class="card h-100 shadow-sm">
                            <div class="card-body">
                                <h5 class="card-title"><%= event.eventName %></h5>
                                <h6 class="card-subtitle mb-2 text-muted">📍 <%= event.location %></h6>
                                <p class="card-text">
                                    <strong> Date:</strong> <%= event.formattedDate %><br>
                                    <%= event.description %>
                                </p>
                            </div>
                            <div class="card-footer bg-transparent border-top-0 d-flex justify-content-between">
                                <a href="/events/<%= event.eventId %>" class="btn btn-outline-primary btn-sm">View Details</a>
                                <a href="/editEvent/<%= event.eventId %>" class="btn btn-outline-warning btn-sm">Edit</a>
                            </div>
                        </div>
                    </div>
                <% }) %>
            </div>
        <% } else { %>
            <div class="alert alert-info" role="alert">
                No events found. Click "+ Add New Event" to create one!
            </div>
        <% } %>
    </div>
</body>

</html>
