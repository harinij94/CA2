<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>All Events</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
</head>

<body>

    <!-- Navbar -->
    <nav class="navbar navbar-expand-sm bg-dark navbar-dark">
        <div class="container-fluid">
            <a class="navbar-brand" href="/">Event Management App</a>

            <ul class="navbar-nav">

                <li class="nav-item">
                    <a class="nav-link" href="/events">View Events</a>
                </li>

                <% if (user && user.role==="admin" ) { %>
                    <li class="nav-item">
                        <a class="nav-link" href="/addEvent">Add Event</a>
                    </li>
                    <% } %>

                        <% if (user) { %>

                            <li class="nav-item">
                                <a class="nav-link" href="/logout">
                                    Logout (<%= user.username %>)
                                </a>
                            </li>

                            <% } else { %>

                                <li class="nav-item">
                                    <a class="nav-link" href="/login">Login</a>
                                </li>

                                <li class="nav-item">
                                    <a class="nav-link" href="/signup">Register</a>
                                </li>

                                <% } %>

            </ul>
        </div>
    </nav>

    <div class="container mt-4">

        <h2 class="mb-4">All Events</h2>

        <div class="row align-items-end mb-4">

            <div class="col-lg-9">

                <form action="/events" method="GET" class="row g-2">

                    <div class="col-md-4">
                        <input type="text" name="keyword" class="form-control" placeholder="Search event..."
                            value="<%= filters ? filters.keyword : '' %>">
                    </div>

                    <div class="col-md-2">
                        <input type="date" name="dateFrom" class="form-control"
                            value="<%= filters ? filters.dateFrom : '' %>">
                    </div>

                    <div class="col-md-2">
                        <input type="date" name="dateTo" class="form-control"
                            value="<%= filters ? filters.dateTo : '' %>">
                    </div>

                    <div class="col-md-2">
                        <select name="sortBy" class="form-select">

                            <option value="date_asc" <%=!filters || filters.sortBy==='date_asc' ? 'selected' : '' %>>
                                Date ↑
                            </option>

                            <option value="date_desc" <%=filters && filters.sortBy==='date_desc' ? 'selected' : '' %>>
                                Date ↓
                            </option>

                            <option value="name_asc" <%=filters && filters.sortBy==='name_asc' ? 'selected' : '' %>>
                                Name A-Z
                            </option>

                            <option value="name_desc" <%=filters && filters.sortBy==='name_desc' ? 'selected' : '' %>>
                                Name Z-A
                            </option>

                        </select>
                    </div>

                    <div class="col-md-2">
                        <button type="submit" class="btn btn-primary w-100">
                            Search
                        </button>
                    </div>

                </form>

            </div>

            <div class="col-lg-3 text-end">

                <% if (user && user.role==="admin" ) { %>

                    <a href="/addEvent" class="btn btn-success">
                        + Add New Event
                    </a>

                    <% } %>

            </div>

        </div>

        <% if (events && events.length> 0) { %>

            <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">

                <% events.forEach(event=> { %>

                    <div class="col">

                        <div class="card h-100 shadow-sm">

                            <div class="card-body">

                                <h5 class="card-title">
                                    <%= event.eventName %>
                                </h5>

                                <h6 class="card-subtitle mb-2 text-muted">
                                    📍 <%= event.location %>
                                </h6>

                                <p class="card-text">
                                    <strong>Date:</strong>
                                    <%= event.formattedDate %>
                                        <br><br>
                                        <%= event.description %>
                                </p>

                            </div>

                            <div class="card-footer bg-transparent">

                                <a href="/events/<%= event.eventId %>" class="btn btn-outline-primary btn-sm">
                                    View Details
                                </a>

                                <% if (user && user.role==="admin" ) { %>

                                    <a href="/editEvent/<%= event.eventId %>" class="btn btn-outline-warning btn-sm">
                                        Edit
                                    </a>

                                    <form action="/deleteEvent/<%= event.eventId %>" method="POST" class="d-inline"
                                        onsubmit="return confirm('Delete this event?');">

                                        <button type="submit" class="btn btn-outline-danger btn-sm">
                                            Delete
                                        </button>

                                    </form>

                                    <% } %>

                            </div>

                        </div>

                    </div>

                    <% }) %>

            </div>

            <% } else { %>

                <div class="alert alert-info">
                    No events found.
                </div>

                <% } %>

    </div>

</body>

</html>