<!DOCTYPE html>
<html>
<head>
    <title>Search Events</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body>
    <div class="container mt-4">
        <h2>Search & Filter Events</h2>
        <div class="mb-3">
            <a href="/" class="btn btn-secondary btn-sm">Home</a>
        </div>

        <!-- Search & filter form -->
        <form action="/searchEvents" method="GET" class="row g-2 mb-4">
            <div class="col-md-4">
                <input type="text" name="keyword" class="form-control" placeholder="Search name, location, description" value="<%= filters.keyword || '' %>">
            </div>
            <div class="col-md-2">
                <input type="date" name="dateFrom" class="form-control" value="<%= filters.dateFrom || '' %>">
            </div>
            <div class="col-md-2">
                <input type="date" name="dateTo" class="form-control" value="<%= filters.dateTo || '' %>">
            </div>
            <div class="col-md-2">
                <select name="sortBy" class="form-select">
                    <option value="date_asc" <%= filters.sortBy === 'date_asc' ? 'selected' : '' %>>Date ↑</option>
                    <option value="date_desc" <%= filters.sortBy === 'date_desc' ? 'selected' : '' %>>Date ↓</option>
                    <option value="name_asc" <%= filters.sortBy === 'name_asc' ? 'selected' : '' %>>Name A–Z</option>
                    <option value="name_desc" <%= filters.sortBy === 'name_desc' ? 'selected' : '' %>>Name Z–A</option>
                </select>
            </div>
            <div class="col-md-2">
                <button type="submit" class="btn btn-primary w-100">Search</button>
            </div>
        </form>

        <p class="text-muted"><%= events.length %> event(s) found</p>

        <table class="table table-striped">
            <thead>
                <tr>
                    <th>Name</th>
                    <th>Location</th>
                    <th>Date</th>
                    <th>Description</th>
                    <th>Action</th>
                </tr>
            </thead>
            <tbody>
                <% events.forEach(event => { %>
                <tr>
                    <td><%= event.eventName %></td>
                    <td><%= event.location %></td>
                    <td><%= event.formattedDate %></td>
                    <td><%= event.description %></td>
                    <td>
                        <form action="/deleteEvent/<%= event.eventId %>" method="POST" onsubmit="return confirm('Delete this event?');">
                            <button type="submit" class="btn btn-danger btn-sm">Delete</button>
                        </form>
                    </td>
                </tr>
                <% }); %>
            </tbody>
        </table>
    </div>
</body>
</html>
