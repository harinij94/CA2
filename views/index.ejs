<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Event Management App</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
</head>

<body class="bg-light">

    <!-- Navigation Bar -->
    <nav class="navbar navbar-expand-sm bg-dark navbar-dark shadow-sm">
        <div class="container">
            <a class="navbar-brand fw-bold" href="/">Event Management App</a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav ms-auto">
                    <li class="nav-item">
                        <a class="nav-link active" href="/">Home</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="/events">View Events</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="/searchEvents">Search Events</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="/addEvent">Add Event</a>
                    </li>
                    
                    <% if (user) { %>
                        <li class="nav-item">
                            <a class="btn btn-outline-light btn-sm ms-2 mt-1" href="/logout">Logout</a>
                        </li>
                    <% } else { %>
                        <li class="nav-item">
                            <a class="nav-link" href="/login">Login</a>
                        </li>
                        <li class="nav-item">
                            <a class="btn btn-primary btn-sm ms-2 mt-1" href="/register">Register</a>
                        </li>
                    <% } %>
                </ul>
            </div>
        </div>
    </nav>

    <!-- Hero Section -->
    <div class="bg-white border-bottom py-5 shadow-sm">
        <div class="container text-center py-4">
            <% if (user) { %>
                <span class="badge bg-primary-subtle text-primary fw-semibold px-3 py-2 rounded-pill mb-3">
                    Welcome back, <%= user.username || 'User' %>!
                </span>
            <% } else { %>
                <span class="badge bg-secondary-subtle text-secondary fw-semibold px-3 py-2 rounded-pill mb-3">
                    Event Hub
                </span>
            <% } %>
            
            <h1 class="display-4 fw-bold text-dark">Plan, Organize, and Explore Events</h1>
            <p class="lead text-muted mx-auto" style="max-width: 650px;">
                Your all-in-one platform to discover upcoming activities, search locations, and seamlessly coordinate new events.
            </p>
            <div class="d-flex justify-content-center gap-3 mt-4">
                <a href="/events" class="btn btn-primary btn-lg px-4 fw-semibold shadow-sm">Browse All Events</a>
                <a href="/addEvent" class="btn btn-outline-secondary btn-lg px-4 fw-semibold">+ Create Event</a>
            </div>
        </div>
    </div>

    <!-- Quick Features Section -->
    <div class="container py-5">
        <div class="row g-4">
            
            <!-- Card 1: View Events -->
            <div class="col-md-4">
                <div class="card h-100 border-0 shadow-sm p-3">
                    <div class="card-body">
                        <div class="fs-1 text-primary mb-2">📅</div>
                        <h5 class="card-title fw-bold">Explore Events</h5>
                        <p class="card-text text-muted">
                            Browse all active upcoming events complete with location details and formatted dates.
                        </p>
                        <a href="/events" class="btn btn-link p-0 fw-semibold text-decoration-none">View All Events →</a>
                    </div>
                </div>
            </div>

            <!-- Card 2: Search & Filter -->
            <div class="col-md-4">
                <div class="card h-100 border-0 shadow-sm p-3">
                    <div class="card-body">
                        <div class="fs-1 text-primary mb-2">🔍</div>
                        <h5 class="card-title fw-bold">Search & Filter</h5>
                        <p class="card-text text-muted">
                            Find specific events instantly using keyword filters, custom date ranges, and sorting options.
                        </p>
                        <a href="/searchEvents" class="btn btn-link p-0 fw-semibold text-decoration-none">Search Database →</a>
                    </div>
                </div>
            </div>

            <!-- Card 3: Add Event -->
            <div class="col-md-4">
                <div class="card h-100 border-0 shadow-sm p-3">
                    <div class="card-body">
                        <div class="fs-1 text-primary mb-2">➕</div>
                        <h5 class="card-title fw-bold">Create Events</h5>
                        <p class="card-text text-muted">
                            Easily post a new event with location data, custom descriptions, and scheduled dates.
                        </p>
                        <a href="/addEvent" class="btn btn-link p-0 fw-semibold text-decoration-none">Add New Event →</a>
                    </div>
                </div>
            </div>

        </div>
    </div>

    <script href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html> 