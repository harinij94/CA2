<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Event Manager</title>

    <!-- Bootstrap 5 CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

    <style>
        body {
            background-color: #f8f9fa;
        }
    </style>
</head>

<body class="d-flex flex-column min-vh-100">

    <!-- Header -->
    <nav class="navbar navbar-dark bg-dark shadow-sm py-3">
        <div class="container justify-content-center">
            <a class="navbar-brand fw-bold fs-3" href="/">
                Event Manager
            </a>
        </div>
    </nav>

    <!-- Main Content -->
    <main class="container my-auto py-5 text-center">

        <h1 class="display-4 fw-bold text-dark mb-3">
            Welcome to Event Manager
        </h1>

        <p class="lead text-muted mx-auto mb-4" style="max-width:500px;">
            Your go-to website for event planning.
        </p>

        <% if (user) { %>

            <div class="alert alert-success d-inline-block px-4 py-2 rounded-pill mb-4" role="alert">
                Logged in as:
                <strong>
                    <%= user.username || user.email || "User" %>
                </strong>
            </div>

            <div>
                <a href="/events" class="btn btn-primary btn-lg px-4 rounded-pill shadow-sm fw-semibold">
                    View Events
                </a>

                <% if (user.role !== "admin") { %>
                    <a href="/myEvents" class="btn btn-outline-success btn-lg px-4 rounded-pill fw-semibold ms-2">
                        My Events
                    </a>
                    <% } %>

                <a href="/logout" class="btn btn-outline-danger btn-lg px-4 rounded-pill fw-semibold ms-2">
                    Logout
                </a>
            </div>

            <% } %>

    </main>

    <!-- Footer -->
    <footer class="bg-white border-top py-4 mt-auto">
        <div class="container text-center">

            <% if (!user) { %>

                <p class="text-muted mb-3 fs-5">
                    Please sign in or create an account to get started.
                </p>

                <div class="d-flex justify-content-center gap-3">

                    <a href="/login" class="btn btn-primary btn-lg px-4 rounded-pill shadow-sm fw-semibold">
                        Login
                    </a>

                    <a href="/signup" class="btn btn-outline-secondary btn-lg px-4 rounded-pill fw-semibold">
                        Sign Up
                    </a>

                </div>

                <% } else { %>

                    <p class="text-muted mb-0">
                        Event Manager &copy; <%= new Date().getFullYear() %>
                    </p>

                    <% } %>

        </div>
    </footer>

    <!-- Bootstrap JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

</body>

</html>