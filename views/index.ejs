<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Event Management App</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
</head>

<body>

    <!-- Navigation Bar -->
    <nav class="navbar navbar-expand-sm navbar-dark bg-dark">
        <div class="container-fluid">

            <a class="navbar-brand" href="/">Event Management App</a>

            <ul class="navbar-nav">

                <li class="nav-item">
                    <a class="nav-link active" href="/">Home</a>
                </li>

            </ul>

        </div>
    </nav>

    <!-- Homepage -->
    <div class="container text-center mt-5">

        <h1 class="display-4 mb-3">Welcome to Event Management App</h1>

        <p class="lead">
            Please log in or create an account to access the Event Management System.
        </p>

        <hr class="my-4">

        <div class="mt-4">

            <a href="/login" class="btn btn-primary btn-lg me-3">
                Login
            </a>

            <a href="/register" class="btn btn-success btn-lg">
                Register
            </a>

        </div>

    </div>

    <!-- Quick Features Section -->
    <div class="container py-5">
        <div class="row g-4">
            
            <!-- Card 1: View Events -->
            <div class="col-md-4">
                <div class="card h-100 border-0 shadow-sm p-3">
                    <div class="card-body">
                        <div class="fs-1 text-primary mb-2">📅</div>
                        <h5 class="card-title fw-bold">Explore Events</h5>
                        <p class="card-text text-muted">
                            Browse all active upcoming events complete with location details and formatted dates.
                        </p>
                        <a href="/events" class="btn btn-link p-0 fw-semibold text-decoration-none">View All Events →</a>
                    </div>
                </div>
            </div>

            <!-- Card 2: Search & Filter -->
            <div class="col-md-4">
                <div class="card h-100 border-0 shadow-sm p-3">
                    <div class="card-body">
                        <div class="fs-1 text-primary mb-2">🔍</div>
                        <h5 class="card-title fw-bold">Search & Filter</h5>
                        <p class="card-text text-muted">
                            Find specific events instantly using keyword filters, custom date ranges, and sorting options.
                        </p>
                        <a href="/searchEvents" class="btn btn-link p-0 fw-semibold text-decoration-none">Search Database →</a>
                    </div>
                </div>
            </div>

            <!-- Card 3: Add Event -->
            <div class="col-md-4">
                <div class="card h-100 border-0 shadow-sm p-3">
                    <div class="card-body">
                        <div class="fs-1 text-primary mb-2">➕</div>
                        <h5 class="card-title fw-bold">Create Events</h5>
                        <p class="card-text text-muted">
                            Easily post a new event with location data, custom descriptions, and scheduled dates.
                        </p>
                        <a href="/addEvent" class="btn btn-link p-0 fw-semibold text-decoration-none">Add New Event →</a>
                    </div>
                </div>
            </div>

        </div>
    </div>

    <script href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html> 