<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>My Events</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
</head>

<body>

    <!-- Navbar -->
    <nav class="navbar navbar-expand-sm bg-dark navbar-dark">
        <div class="container-fluid">
            <a class="navbar-brand" href="/">Event Management App</a>

            <ul class="navbar-nav">

                <li class="nav-item">
                    <a class="nav-link" href="/events">All Events</a>
                </li>

                <% if (user) { %>

                    <li class="nav-item">
                        <a class="nav-link active" href="/myEvents">My Events</a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link" href="/logout">
                            Logout (<%= user.username %>)
                        </a>
                    </li>

                    <% } else { %>

                        <li class="nav-item">
                            <a class="nav-link" href="/login">Login</a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link" href="/signup">Register</a>
                        </li>

                        <% } %>

            </ul>
        </div>
    </nav>

    <div class="container mt-4">

        <h2 class="mb-4">My Events</h2>
        <p class="text-muted">Events you've selected to attend.</p>

        <% if (events && events.length > 0) { %>

            <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">

                <% events.forEach(event => { %>

                    <div class="col">

                        <div class="card h-100 shadow-sm border-success">

                            <div class="card-body">

                                <h5 class="card-title">
                                    <%= event.eventName %>
                                </h5>

                                <h6 class="card-subtitle mb-2 text-muted">
                                    📍 <%= event.location %>
                                </h6>

                                <p class="card-text">
                                    <strong>Date:</strong>
                                    <%= event.formattedDate %>
                                    <br><br>
                                    <strong>Description:</strong><br>
                                    <%= event.description %>
                                </p>

                            </div>

                            <div class="card-footer bg-transparent d-flex gap-2">

                                <a href="/events/<%= event.eventId %>" class="btn btn-outline-primary btn-sm">
                                    View Details
                                </a>

                                <form action="/events/<%= event.eventId %>/unregister" method="POST">
                                    <button type="submit" class="btn btn-outline-danger btn-sm">
                                        Remove
                                    </button>
                                </form>

                            </div>

                        </div>

                    </div>

                    <% }) %>

            </div>

            <% } else { %>

                <div class="alert alert-info">
                    You haven't selected any events yet. Head over to
                    <a href="/events">All Events</a> to pick some!
                </div>

                <% } %>

    </div>

</body>

</html>
